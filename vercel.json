{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/jupiter/quote", "destination": "/api/jupiter" },
    { "source": "/api/jupiter/swap",  "destination": "/api/jupiter" },
    { "source": "/(.*)",              "destination": "/index.html"  }
  ]
}
