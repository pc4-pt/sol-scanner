{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/quote", "destination": "/api/quote" },
    { "source": "/api/swap",  "destination": "/api/swap"  },
    { "source": "/:path*",    "destination": "/index.html" }
  ]
}
